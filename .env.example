# ===== AUTHENTICATION & SESSION =====
SESSION_SECRET=your-super-secret-session-key-change-this-in-production
NODE_ENV=development

# ===== ADMIN =====
# Admin email (this user gets admin access). Alternative: ADMIN_USER_ID with numeric DB id.
ADMIN_EMAIL=admin@smpin.uz
# ADMIN_USER_ID=1

# ===== GOOGLE OAUTH =====
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# ===== TELEGRAM BOT =====
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here
TELEGRAM_BOT_HANDLE=your_bot_username
ADMIN_CHAT_ID=your-admin-chat-id-number

# ===== SMM API KEYS =====
# API 1: Telegram, TikTok subscribers (Service IDs 1-9)
SMM_API_KEY_1=your-smmya-api-key

# API 2: Instagram followers, likes (Service IDs 10-11)
SMM_API_KEY_2=your-niva-miners-api-key

# API 3: Instagram views (Service ID 12)
SMM_API_KEY_3=your-uzbek-seen-api-key

# ===== CORS & SECURITY =====
CORS_ORIGIN=http://localhost:3000
